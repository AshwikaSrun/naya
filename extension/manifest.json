{
  "manifest_version": 3,
  "name": "Naya — Resale Price Intelligence",
  "version": "1.0.0",
  "description": "Instant deal scores, cross-platform price checks, and wishlist saves while you browse eBay, Grailed, Depop, and Poshmark.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.ebay.com/*",
    "https://www.grailed.com/*",
    "https://www.depop.com/*",
    "https://poshmark.com/*",
    "https://www.nayaeditorial.shop/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ebay.com/itm/*",
        "https://www.grailed.com/listings/*",
        "https://www.depop.com/products/*",
        "https://poshmark.com/listing/*"
      ],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.ebay.com/sch/*",
        "https://www.grailed.com/shop/*",
        "https://www.grailed.com/designers/*",
        "https://www.depop.com/search/*",
        "https://poshmark.com/search*"
      ],
      "js": ["scanner.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
